{lib, ...}: {
  programs.noctalia-shell = {
    enable = true;
    settings = {
      "general" = {
        showScreenCorners = true;
      };
      "colorSchemes" = {
        predefinedScheme = "Mine";
        darkMode = true;
        useWallpaperColors = false;
      };
      "bar" = {
        density = "compact";
        position = "top";
        barType = "floating";
        showCapsule = true;
        displayMode = "non_exclusive";
        widgets = {
          left = [
            {id = "Launcher";}
            {
              id = "Clock";
              formatHorizontal = "HH:mm ddd, MMM dd";
              formatVertical = "HH mm";
              useMonospacedFont = true;
              usePrimaryColor = false;
            }
            {id = "SystemMonitor";}
            {
              id = "VPN";
              displayMode = "alwaysShow";
            }
            {id = "ActiveWindow";}
            {id = "MediaMini";}
          ];
          center = [
            {
              id = "Workspace";
              hideUnoccupied = false;
              labelMode = "index";
            }
          ];
          right = [
            {id = "Network";}
            {
              id = "Battery";
              showNoctaliaPerformance = true;
            }
            {id = "Bluetooth";}
            {id = "Tray";}
            {id = "NotificationHistory";}
            {id = "Volume";}
            {
              id = "ControlCenter";
              useDistroLogo = true;
              icon = "noctalia";
              enableColorization = true;
            }
          ];
        };
      };
      "notifications"."backgroundOpacity" = 1.0;
      "osd"."backgroundOpacity" = 1.0;
      "ui" = {
        "fontDefault" = lib.mkForce "JetBrains Mono";
        "fontFixed" = lib.mkForce "JetBrains Mono";
        "translucentWidgets" = false;
        "boxBorderEnabled" = true;
      };
      "appLauncher"."terminalCommand" = "ghostty";
    };
  };
}
